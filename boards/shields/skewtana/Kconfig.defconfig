if SHIELD_SKEWTANA_LEFT

# Name must be less than 16 characters long!
config ZMK_KEYBOARD_NAME
    default "Skewtana"
config ZMK_SPLIT_ROLE_CENTRAL
    default y

endif


if SHIELD_SKEWTANA_RIGHT
# Name must be less than 16 characters long!
config ZMK_KEYBOARD_NAME
    default "Skewtana"

endif


if SHIELD_SKEWTANA_LEFT || SHIELD_SKEWTANA_RIGHT

config ZMK_SPLIT
    default y

endif